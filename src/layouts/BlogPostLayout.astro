---
import Layout from './Layout.astro';
import { Navbar } from '../components/landing/Navbar';
import { Footer } from '../components/landing/Footer';

interface Props {
  title: string;
  description: string;
  publishDate?: string;
  tldr: string;
  keyTakeaways: string[];
  schemas?: Record<string, any>[];
}

const { 
  title, 
  description, 
  publishDate = "June 18, 2026", 
  tldr, 
  keyTakeaways,
  schemas = [] 
} = Astro.props;
---

<Layout title={title} description={description}>
  {schemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
  <Navbar client:load />

  <main class="pt-32 pb-24 max-w-4xl mx-auto px-6 relative z-10">
    <a href="/blog" class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent-600 hover:text-accent-700 transition-colors uppercase tracking-widest font-sans mb-8">
      <span>←</span> Back to Blog
    </a>

    <article class="bg-cream-50 rounded-sm border border-ink-900/15 shadow-2xl p-8 md:p-12 vintage-border relative overflow-hidden">
      <!-- Decorative vintage wash -->
      <div class="absolute inset-0 bg-gradient-to-b from-amber-400/5 to-transparent pointer-events-none" />

      <header class="relative z-10 mb-10 text-center">
        <div class="vintage-divider text-xs font-semibold uppercase tracking-[0.3em] mb-4 text-ink-500 font-sans">
          <span class="flourish text-base">✦</span>
          <span class="mx-3">Nexus AI Blog</span>
          <span class="flourish text-base">✦</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-medium text-ink-900 leading-[1.15] mb-6">
          {title}
        </h1>
        <div class="text-xs text-ink-400 font-sans uppercase tracking-widest">
          Published: {publishDate} · Written by Nexus Editorial Team
        </div>
      </header>

      <!-- TL;DR Highlight Box (GEO Optimization Requirement) -->
      <div class="relative z-10 bg-cream-100/80 rounded-sm border border-accent-600/20 p-6 mb-10 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-accent-500/10 rounded-full blur-2xl pointer-events-none" />
        <h3 class="text-xs font-bold text-accent-700 uppercase tracking-widest font-sans mb-2 flex items-center gap-1.5">
          <span>⚡</span> TL;DR / Quick Summary
        </h3>
        <p class="font-serif italic text-ink-800 text-base leading-relaxed mb-4">
          {tldr}
        </p>
        <div class="border-t border-ink-900/5 pt-3.5">
          <h4 class="text-xs font-semibold text-ink-700 uppercase tracking-wider font-sans mb-2">Key Takeaways:</h4>
          <ul class="space-y-1.5">
            {keyTakeaways.map(takeaway => (
              <li class="flex items-start gap-2 text-xs text-ink-600 font-sans">
                <span class="text-accent-600 font-bold">•</span>
                <span>{takeaway}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Main Body content wrapper -->
      <div class="relative z-10 prose prose-stone max-w-none text-sm text-ink-700 leading-relaxed space-y-6 font-sans">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* GEO Content Formatting styles (Tables, Q&A, lists) */
  .prose h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #1c1917; /* ink-900 equivalent */
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(28, 25, 23, 0.1);
    padding-bottom: 0.5rem;
  }

  .prose h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #1c1917;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .prose p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }

  .prose strong {
    color: #1c1917;
    font-weight: 600;
  }

  /* Styling for Comparison Tables (GEO High-Density Widget) */
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.8rem;
    border: 1px solid rgba(28, 25, 23, 0.15);
  }

  .prose th {
    background-color: #f5f3ef; /* cream-100 equivalent */
    color: #1c1917;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(28, 25, 23, 0.15);
    text-align: left;
  }

  .prose td {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(28, 25, 23, 0.15);
    color: #44403c;
  }

  .prose tr:nth-child(even) {
    background-color: rgba(245, 243, 239, 0.4);
  }

  /* List Styling */
  .prose ul, .prose ol {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose ul {
    list-style-type: disc;
  }

  .prose ol {
    list-style-type: decimal;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  /* FAQ Blocks */
  .faq-q {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    color: #c2410c; /* accent-700 equivalent */
    margin-top: 1.5rem;
  }

  .faq-a {
    color: #44403c;
    margin-top: 0.25rem;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 2px solid rgba(194, 65, 12, 0.3);
  }

  /* Code block highlight (GEO requirement) */
  .prose pre {
    background-color: #1c1917;
    color: #f5f3ef;
    padding: 1rem;
    border-radius: 0.125rem;
    font-family: monospace;
    font-size: 0.8rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose code {
    font-family: monospace;
    background-color: rgba(28, 25, 23, 0.05);
    padding: 0.125rem 0.25rem;
    border-radius: 0.125rem;
    font-size: 0.9em;
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
  }
</style>
