---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/landing/Navbar';
import { Footer } from '../components/landing/Footer';
---

<Layout 
  title="Documentation — Nexus AI" 
  description="Explore guides, references, and tutorials for setting up workspaces, configuring the AI Chief of Staff, and mapping company memory."
>
  <Navbar client:load />

  <main class="relative z-10 font-sans selection:bg-accent-500/20 text-ink-900 antialiased paper-texture pt-32 pb-24">
    <!-- Header Section with Search Box -->
    <section class="max-w-4xl mx-auto px-6 text-center mb-16">
      <div class="vintage-divider text-xs font-semibold uppercase tracking-[0.3em] mb-8 text-ink-500">
        <span class="flourish text-base">✦</span>
        <span class="mx-3">Knowledge Base</span>
        <span class="flourish text-base">✦</span>
      </div>

      <h1 class="font-serif text-5xl font-semibold leading-tight tracking-tight text-ink-900 mb-6">
        How can we help?
      </h1>
      
      <!-- Sleek search bar placeholder -->
      <div class="max-w-xl mx-auto relative flex items-center">
        <div class="absolute left-4 flex items-center pointer-events-none">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input 
          type="text" 
          placeholder="Search documentation (e.g. 'Notion import', 'SSO')..." 
          class="w-full bg-cream-50/50 border border-ink-900/15 rounded-full pl-11 pr-4 py-3.5 text-xs focus:outline-none focus:border-ink-900/40 focus:ring-1 focus:ring-ink-900/10 placeholder:text-ink-400 font-sans shadow-sm"
          disabled
        />
      </div>
    </section>

    <!-- Help Categories Grid -->
    <section class="max-w-5xl mx-auto px-6 mb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Getting Started -->
        <div class="border border-ink-900/10 bg-cream-50/30 p-8 rounded-lg shadow-sm flex flex-col gap-5 hover:border-ink-900/25 hover:shadow-md transition-all duration-300">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
            <h3 class="font-serif text-xl font-semibold text-ink-900">Getting Started</h3>
          </div>
          <p class="text-xs text-ink-600 leading-relaxed font-sans">
            Learn the basics of Nexus AI, set up your initial team workspace parameters, and invite your department members.
          </p>
          <ul class="space-y-3.5 text-xs font-semibold text-accent-700 font-sans border-t border-ink-900/5 pt-4">
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Introduction to the AI Chief of Staff</a></li>
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Workspace Setup Checklist</a></li>
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Inviting Members & Managing Roles</a></li>
          </ul>
        </div>

        <!-- AI Chief of Staff -->
        <div class="border border-ink-900/10 bg-cream-50/30 p-8 rounded-lg shadow-sm flex flex-col gap-5 hover:border-ink-900/25 hover:shadow-md transition-all duration-300">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            <h3 class="font-serif text-xl font-semibold text-ink-900">AI Chief of Staff</h3>
          </div>
          <p class="text-xs text-ink-600 leading-relaxed font-sans">
            How to leverage daily briefings, trigger auto-task triaging, configure calendar defense rules, and use the interactive AI assistant.
          </p>
          <ul class="space-y-3.5 text-xs font-semibold text-accent-700 font-sans border-t border-ink-900/5 pt-4">
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Configuring Daily Executive Briefings</a></li>
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Managing Commits & Auto Task Creation</a></li>
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Setting Up Smart Calendar Blocking</a></li>
          </ul>
        </div>

        <!-- Organizational Memory -->
        <div class="border border-ink-900/10 bg-cream-50/30 p-8 rounded-lg shadow-sm flex flex-col gap-5 hover:border-ink-900/25 hover:shadow-md transition-all duration-300">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <h3 class="font-serif text-xl font-semibold text-ink-900">Organizational Memory</h3>
          </div>
          <p class="text-xs text-ink-600 leading-relaxed font-sans">
            Understand how Nexus AI builds your private knowledge graph, manages context sweeps, and generates automated offboarding handovers.
          </p>
          <ul class="space-y-3.5 text-xs font-semibold text-accent-700 font-sans border-t border-ink-900/5 pt-4">
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Building the Context Graph</a></li>
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Triggering Automated Employee Handovers</a></li>
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Semantic Search Queries Reference</a></li>
          </ul>
        </div>

        <!-- API & Integrations -->
        <div class="border border-ink-900/10 bg-cream-50/30 p-8 rounded-lg shadow-sm flex flex-col gap-5 hover:border-ink-900/25 hover:shadow-md transition-all duration-300">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <h3 class="font-serif text-xl font-semibold text-ink-900">API & Integrations</h3>
          </div>
          <p class="text-xs text-ink-600 leading-relaxed font-sans">
            Connect Slack, Gmail, Outlook, Zoom, and low-code automation webhooks (such as n8n) directly into your workspace.
          </p>
          <ul class="space-y-3.5 text-xs font-semibold text-accent-700 font-sans border-t border-ink-900/5 pt-4">
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Connecting Gmail & Outlook IMAP/SMTP</a></li>
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Slack Integration Setup Guide</a></li>
            <li class="flex items-center gap-2"><span class="text-ink-300">→</span><a href="#" class="hover:text-accent-900 transition-colors">Triggering Workflows via n8n Webhooks</a></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Support CTA Section -->
    <section class="max-w-4xl mx-auto px-6 text-center border-t border-ink-900/10 pt-16">
      <h3 class="font-serif text-2xl font-semibold text-ink-900 mb-3">Still have questions?</h3>
      <p class="text-xs text-ink-600 leading-relaxed max-w-md mx-auto font-sans mb-6">
        Can't find the documentation you need? Connect directly with our developer team for support.
      </p>
      <a 
        href="/contact" 
        class="px-8 py-3 rounded-full border border-ink-900/15 hover:border-ink-900/40 text-ink-900 font-medium text-xs tracking-wider uppercase transition-all hover:bg-ink-900/[0.02]"
      >
        Contact Support
      </a>
    </section>
  </main>

  <Footer />
</Layout>
