---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/landing/Navbar';
import { Footer } from '../components/landing/Footer';

const seoTitle = "System Status — Aixentrix";
const seoDescription = "Live uptime tracking, response times, and incident logs for Aixentrix services.";
---

<Layout title={seoTitle} description={seoDescription}>
  <Navbar client:load />

  <main class="pt-32 pb-24 max-w-4xl mx-auto px-6 relative z-10">
    <article class="bg-cream-50 rounded-sm border border-ink-900/15 shadow-2xl p-8 md:p-12 vintage-border relative overflow-hidden">
      <!-- Decorative vintage wash -->
      <div class="absolute inset-0 bg-gradient-to-b from-amber-400/5 to-transparent pointer-events-none" />

      <header class="relative z-10 mb-10 text-center">
        <div class="vintage-divider text-xs font-semibold uppercase tracking-[0.3em] mb-4 text-ink-500 font-sans">
          <span class="flourish text-base">✦</span>
          <span class="mx-3">Service Availability</span>
          <span class="flourish text-base">✦</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-medium text-ink-900 leading-tight mb-6 flex items-center justify-center gap-3">
          System Status
        </h1>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/10 text-emerald-800 border border-emerald-500/20 text-xs font-semibold font-sans uppercase tracking-wider mx-auto">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          All Systems Operational
        </div>
      </header>

      <div class="relative z-10 prose prose-stone max-w-none text-sm text-ink-700 leading-relaxed space-y-8 font-sans">
        
        <!-- Live Services Grid -->
        <section>
          <h2 class="font-serif text-2xl font-semibold text-ink-900 mb-4 border-b border-ink-900/10 pb-2">
            Active Services
          </h2>
          <div class="space-y-3.5 mt-4">
            <!-- Service 1 -->
            <div class="flex items-center justify-between border-b border-ink-900/5 pb-3">
              <div>
                <h4 class="font-serif text-base font-bold text-ink-900 mb-0.5">Aixentrix Web App</h4>
                <p class="text-[10px] text-ink-500 font-sans">Vercel Edge Network · Washington, D.C. (iad1)</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-ink-500">99.98% Uptime</span>
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-500/10 px-2 py-0.5 rounded">Operational</span>
              </div>
            </div>

            <!-- Service 2 -->
            <div class="flex items-center justify-between border-b border-ink-900/5 pb-3">
              <div>
                <h4 class="font-serif text-base font-bold text-ink-900 mb-0.5">Operational Databases</h4>
                <p class="text-[10px] text-ink-500 font-sans">Supabase Cloud PostgreSQL · AWS Mumbai (ap-south-1)</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-ink-500">99.99% Uptime</span>
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-500/10 px-2 py-0.5 rounded">Operational</span>
              </div>
            </div>

            <!-- Service 3 -->
            <div class="flex items-center justify-between border-b border-ink-900/5 pb-3">
              <div>
                <h4 class="font-serif text-base font-bold text-ink-900 mb-0.5">Real-time Handover Engine</h4>
                <p class="text-[10px] text-ink-500 font-sans">Background Workers · Serverless Architecture</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-ink-500">100.0% Uptime</span>
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-500/10 px-2 py-0.5 rounded">Operational</span>
              </div>
            </div>

            <!-- Service 4 -->
            <div class="flex items-center justify-between border-b border-ink-900/5 pb-3">
              <div>
                <h4 class="font-serif text-base font-bold text-ink-900 mb-0.5">AI Memory & Context Graph Service</h4>
                <p class="text-[10px] text-ink-500 font-sans">Vector Search Indexing · Gemini Core API</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-ink-500">99.95% Uptime</span>
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-500/10 px-2 py-0.5 rounded">Operational</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Metrics -->
        <section class="grid grid-cols-1 sm:grid-cols-3 gap-6 my-10 text-center">
          <div class="border border-ink-900/10 p-5 rounded bg-cream-100/30">
            <div class="text-xs font-semibold text-ink-500 uppercase tracking-wider mb-1">Response Time</div>
            <div class="font-serif text-2xl font-bold text-ink-900">42ms</div>
          </div>
          <div class="border border-ink-900/10 p-5 rounded bg-cream-100/30">
            <div class="text-xs font-semibold text-ink-500 uppercase tracking-wider mb-1">90-Day Uptime</div>
            <div class="font-serif text-2xl font-bold text-ink-900">99.978%</div>
          </div>
          <div class="border border-ink-900/10 p-5 rounded bg-cream-100/30">
            <div class="text-xs font-semibold text-ink-500 uppercase tracking-wider mb-1">Open Incidents</div>
            <div class="font-serif text-2xl font-bold text-emerald-700">0</div>
          </div>
        </section>

        <!-- Incidents -->
        <section>
          <h2 class="font-serif text-2xl font-semibold text-ink-900 mb-4 border-b border-ink-900/10 pb-2">
            Incident Log (Past 30 Days)
          </h2>
          <p class="text-xs text-ink-600 italic">
            No incidents reported in the past 30 days. System operations are completely stable.
          </p>
        </section>

      </div>
    </article>
  </main>

  <Footer />
</Layout>
