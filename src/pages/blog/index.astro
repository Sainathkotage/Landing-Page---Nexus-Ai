---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/landing/Navbar';
import { Footer } from '../../components/landing/Footer';

const posts = [
  {
    title: "What Is an AI Agent? The Ultimate Guide to AI Agents (2026)",
    desc: "The definitive 20,000-word guide covering AI agent definitions, architectures, memory systems, reasoning frameworks, enterprise use cases, building tools, and the future of autonomous AI.",
    slug: "what-is-an-ai-agent-ultimate-guide",
    date: "June 21, 2026",
    readTime: "90 min read",
    tag: "Ultimate Guide"
  },
  {
    title: "Notion's Biggest AI Update Yet — But Is It Trying to Become Too Many Things?",
    desc: "An analysis of Notion's latest developer and AI platform features, and why this shift towards an all-in-one workspace operating system introduces complex trade-offs.",
    slug: "notions-biggest-ai-update-yet",
    date: "June 21, 2026",
    readTime: "8 min read",
    tag: "Industry Analysis"
  },
  {
    title: "What is an AI Chief of Staff? Platform Definition & Insights",
    desc: "An entry-level deep dive defining the AI Chief of Staff workspace category, core capabilities, and how it automates administrative workflows.",
    slug: "what-is-an-ai-chief-of-staff",
    date: "June 18, 2026",
    readTime: "5 min read",
    tag: "Category Definition"
  },
  {
    title: "Nexus AI vs. Notion: Manual Wiki vs. Active Assistant",
    desc: "A feature-by-feature comparison comparing active AI operating systems to manual document wikis.",
    slug: "ai-workspace-vs-notion",
    date: "June 18, 2026",
    readTime: "7 min read",
    tag: "Comparison Engine"
  },
  {
    title: "Preserving Context: Automated Employee Handover & Company Memory",
    desc: "How Nexus AI programmatically scans communication histories and builds handover documents to stop tribal knowledge leakage.",
    slug: "employee-handover-automation",
    date: "June 18, 2026",
    readTime: "6 min read",
    tag: "Core Capability"
  }
];
---

<Layout title="Nexus AI Blog — Insights on AI Workspaces & Knowledge Retention" description="Guides, tutorials, comparisons, and research from the Nexus AI team on building the active company operating system.">
  <Navbar client:load />

  <main class="pt-32 pb-24 max-w-6xl mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="vintage-divider text-xs font-semibold uppercase tracking-[0.3em] mb-6 text-ink-500 font-sans">
        <span class="flourish text-base">✦</span>
        <span class="mx-3">Perspectives</span>
        <span class="flourish text-base">✦</span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl font-medium text-ink-900 leading-[1.05] mb-6">
        The <span class="italic text-accent-500 font-normal">Nexus AI Blog</span>
      </h1>
      <p class="text-lg text-ink-500 leading-relaxed font-serif italic">
        Factual guides, strategic deep dives, and comparisons on building the future of autonomous company memory.
      </p>
    </div>

    <!-- Blog Posts Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      {posts.map(post => (
        <article class="vintage-card rounded-sm border border-ink-900/15 p-6 relative overflow-hidden flex flex-col hover:-translate-y-1 transition-all duration-300">
          <div class="absolute inset-0 bg-gradient-to-b from-amber-400/5 to-transparent pointer-events-none" />
          <div class="relative z-10 flex-1">
            <span class="inline-block px-2 py-0.5 bg-accent-500/10 text-accent-700 text-[10px] font-semibold uppercase tracking-wider rounded-sm font-sans mb-4">
              {post.tag}
            </span>
            <h2 class="font-serif text-xl font-medium text-ink-900 mb-3 hover:text-accent-600 transition-colors">
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
            </h2>
            <p class="text-sm text-ink-500 leading-relaxed font-sans mb-6">
              {post.desc}
            </p>
          </div>
          <div class="relative z-10 border-t border-ink-900/10 pt-4 flex justify-between items-center text-xs text-ink-400 font-sans uppercase tracking-widest mt-auto">
            <span>{post.date}</span>
            <span>{post.readTime}</span>
          </div>
        </article>
      ))}
    </div>
  </main>

  <Footer />
</Layout>
