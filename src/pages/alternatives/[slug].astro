---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/landing/Navbar';
import { Footer } from '../../components/landing/Footer';
import { comparisons } from '../../lib/data/comparisons';
import { Check, X, Shield, ArrowLeft, ArrowUpRight } from 'lucide-react';

export async function getStaticPaths() {
  return comparisons.map((comparison) => ({
    params: { slug: comparison.slug },
    props: { comparison }
  }));
}

const { comparison } = Astro.props;

// Schema.org Structured Data
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://aixentrix.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Alternatives",
      "item": `https://aixentrix.com/alternatives/${comparison.slug}`
    }
  ]
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Aixentrix AI Workspace",
  "description": `The proactive AI Chief of Staff and best alternative to ${comparison.name} for modern collaborative teams.`,
  "brand": {
    "@type": "Brand",
    "name": "Aixentrix"
  },
  "offers": {
    "@type": "Offer",
    "price": "0.00",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": comparison.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q.replace(/Aixentrix/g, `Aixentrix (The Best ${comparison.name} Alternative)`),
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const schemas = [breadcrumbSchema, productSchema, faqSchema];
const pageTitle = `Best ${comparison.name} Alternative (2026) — Aixentrix`;
const pageDescription = `Looking for the best ${comparison.name} alternative? Compare features, pros, and cons to see how Aixentrix automates workspace context, tasks, and document memory.`;
---

<Layout title={pageTitle} description={pageDescription} schemas={schemas}>
  <Navbar client:load />

  <main class="pt-32 pb-24 max-w-4xl mx-auto px-6 relative z-10 font-sans">
    
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-2 text-xs font-semibold text-ink-500 uppercase tracking-widest">
      <a href="/" class="hover:text-accent-600 transition-colors">Home</a>
      <span class="text-ink-300">/</span>
      <a href="/compare/notion" class="hover:text-accent-600 transition-colors">Alternatives</a>
      <span class="text-ink-300">/</span>
      <span class="text-ink-900 font-bold">{comparison.name} Alternative</span>
    </nav>

    <article class="bg-cream-50 rounded-sm border border-ink-900/15 shadow-2xl p-8 md:p-12 vintage-border relative overflow-hidden">
      <!-- Decorative vintage wash -->
      <div class="absolute inset-0 bg-gradient-to-b from-amber-400/5 to-transparent pointer-events-none" />

      <header class="relative z-10 mb-10 text-center border-b border-ink-900/10 pb-8">
        <div class="vintage-divider text-xs font-semibold uppercase tracking-[0.3em] mb-4 text-ink-500">
          <span class="flourish text-base">✦</span>
          <span class="mx-3">The Best {comparison.name} Alternative</span>
          <span class="flourish text-base">✦</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-medium text-ink-900 leading-tight mb-6">
          Aixentrix: An Active Alternative to {comparison.name}
        </h1>
        <p class="text-sm text-ink-700 leading-relaxed max-w-2xl mx-auto italic">
          {comparison.introduction}
        </p>
      </header>

      <div class="relative z-10 prose prose-stone max-w-none text-sm text-ink-700 leading-relaxed space-y-10">
        
        <!-- Comparison Table -->
        <section>
          <h2 class="font-serif text-2xl font-semibold text-ink-900 mb-4 border-b border-ink-900/10 pb-2">
            Why Teams Switch from {comparison.name} to Aixentrix
          </h2>
          <div class="overflow-x-auto border border-ink-900/15 rounded">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-cream-100">
                  <th class="p-3 text-xs font-semibold uppercase tracking-wider text-ink-900 border-b border-ink-900/15">Feature Capability</th>
                  <th class="p-3 text-xs font-semibold uppercase tracking-wider text-ink-900 border-b border-ink-900/15">{comparison.name}</th>
                  <th class="p-3 text-xs font-semibold uppercase tracking-wider text-ink-900 border-b border-ink-900/15 bg-accent-500/5">Aixentrix (Active Alternative)</th>
                </tr>
              </thead>
              <tbody>
                {comparison.featuresTable.map((row) => (
                  <tr class="hover:bg-cream-100/20 transition-colors">
                    <td class="p-3 border-b border-ink-900/10 font-medium text-ink-900">{row.feature}</td>
                    <td class="p-3 border-b border-ink-900/10 text-ink-600">{row.competitorValue}</td>
                    <td class="p-3 border-b border-ink-900/10 text-accent-800 font-semibold bg-accent-500/5">{row.aixentrixValue}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- Strengths / Pros Grid -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-8 my-8">
          <div class="border border-ink-900/10 p-6 rounded bg-accent-500/[0.02]">
            <h3 class="font-serif text-lg font-bold text-ink-900 mb-3">Why Aixentrix is Better</h3>
            <ul class="space-y-2">
              {comparison.prosAixentrix.map((pro) => (
                <li class="flex items-start gap-2 text-xs text-ink-700">
                  <span class="text-emerald-700 font-bold">✓</span>
                  <span>{pro}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="border border-ink-900/10 p-6 rounded bg-cream-100/20">
            <h3 class="font-serif text-lg font-bold text-ink-900 mb-3">{comparison.name} Limitations</h3>
            <ul class="space-y-2">
              {comparison.consCompetitor.map((con) => (
                <li class="flex items-start gap-2 text-xs text-ink-700">
                  <span class="text-red-700 font-bold">✗</span>
                  <span>{con}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>

        <!-- Decision Criteria -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="font-serif text-xl font-bold text-ink-900 mb-2">Choose Aixentrix if:</h3>
            <p class="text-xs text-ink-600 leading-relaxed">
              {comparison.idealUseAixentrix}
            </p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-bold text-ink-900 mb-2">Stick with {comparison.name} if:</h3>
            <p class="text-xs text-ink-600 leading-relaxed">
              {comparison.idealUseCompetitor}
            </p>
          </div>
        </section>

        <!-- Migration Pathway -->
        <section class="bg-cream-100/50 p-6 rounded border border-ink-900/10">
          <h3 class="font-serif text-xl font-semibold text-ink-900 mb-3">
            Easy Migration Pathway from {comparison.name}
          </h3>
          <p class="text-xs text-ink-600 leading-relaxed mb-4">
            Transitioning your team workspace from {comparison.name} is quick and self-serve:
          </p>
          <ol class="list-decimal pl-5 space-y-2 text-xs text-ink-600">
            {comparison.migrationGuide.map((step) => (
              <li>{step}</li>
            ))}
          </ol>
        </section>

        <!-- Dynamic FAQs -->
        <section>
          <h2 class="font-serif text-2xl font-semibold text-ink-900 mb-4 border-b border-ink-900/10 pb-2">
            Frequently Asked Questions
          </h2>
          <div class="space-y-4">
            {comparison.faqs.map((faq) => (
              <div>
                <h4 class="font-serif text-base font-bold text-accent-700 mb-1">{faq.q}</h4>
                <p class="text-xs text-ink-600 leading-relaxed pl-3 border-l-2 border-accent-500/20">{faq.a}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Final Conversion CTA -->
        <section class="text-center bg-ink-900 text-cream-50 p-8 rounded shadow-lg mt-10">
          <h3 class="font-serif text-2xl font-medium mb-3">Claim Your Active AI Workspace</h3>
          <p class="text-xs text-cream-200/80 mb-6 max-w-lg mx-auto">
            Switch from manual tracking and graveyards of outdated docs to a workspace that unifies emails, tasks, and memory in Nagpur, India.
          </p>
          <a href="/nexus" class="inline-block px-8 py-3 rounded-full bg-cream-50 hover:bg-cream-100 text-ink-900 font-bold text-xs tracking-wider uppercase transition-all shadow-md">
            Start Free Beta Today
          </a>
        </section>

      </div>
    </article>
  </main>

  <Footer />
</Layout>
